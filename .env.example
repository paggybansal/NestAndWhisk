# Core Django
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SITE_ID=1

# Database
POSTGRES_DB=nestandwhisk
POSTGRES_USER=nestandwhisk
POSTGRES_PASSWORD=nestandwhisk
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nestandwhisk:nestandwhisk@db:5432/nestandwhisk

# Cache / task queue
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL="Nest & Whisk <hello@nestandwhisk.com>"
SERVER_EMAIL=server@nestandwhisk.com
CONTACT_EMAIL=hello@nestandwhisk.com

# Frontend / assets
VITE_DEV_SERVER_URL=http://localhost:5173
VITE_APP_NAME=nest-and-whisk
DJANGO_VITE_DEV_MODE=False

# Docker / runtime bootstrap
DJANGO_BOOTSTRAP_DEMO=0
DJANGO_BOOTSTRAP_ADMIN=0
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Optional AI FAQ assistant
AI_CHAT_ENABLED=False
AI_CHAT_PROVIDER=gemini
AI_CHAT_MODEL=gemini-2.0-flash
AI_CHAT_API_KEY=
AI_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_CHAT_TIMEOUT_SECONDS=12
AI_CHAT_PROJECT_NAME=
AI_CHAT_PROJECT_NUMBER=

# Stripe
STRIPE_PUBLIC_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=inr
STRIPE_ENABLE_UPI=True
MOCK_PAYMENT_ENABLED=True
DEFAULT_PAYMENT_PROVIDER=stripe

# Security / app behavior
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
COOKIE_SAMESITE=Lax

# Admin bootstrap
DJANGO_SUPERUSER_EMAIL=admin@nestandwhisk.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!

# Optional observability
SENTRY_DSN=

